<Window x:Class="Pomodoro.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajustes de Pomodoro"
        Width="380" Height="470"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#194E96"
        SourceInitialized="Window_SourceInitialized"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <Style x:Key="ModeButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="58" />
            <Setter Property="Margin" Value="5,8" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Card"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="2.5"
                                CornerRadius="12"
                                Opacity="0.62">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Card" Property="BorderBrush" Value="White" />
                                <Setter TargetName="Card" Property="Opacity" Value="1" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Card" Property="Opacity" Value="0.35" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      CornerRadius="18"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border CornerRadius="18"
            MouseLeftButtonDown="Surface_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#347FDA" Offset="0" />
                <GradientStop Color="#174B91" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="28" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="64" />
                <RowDefinition Height="28" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="70" />
                <RowDefinition Height="*" />
                <RowDefinition Height="44" />
                <RowDefinition Height="12" />
                <RowDefinition Height="46" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="AJUSTES"
                       Foreground="White"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontWeight="SemiBold"
                       FontSize="28" />

            <TextBlock Grid.Row="2"
                       Text="VOLUMEN"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="15" />

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="58" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="38" Height="38"
                        HorizontalAlignment="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Probar volumen"
                        Click="TestVolume_Click">
                    <Viewbox Margin="4">
                        <Canvas Width="32" Height="32">
                            <Path Fill="White" Data="M 3,12 L 9,12 L 17,5 L 17,27 L 9,20 L 3,20 Z" />
                            <Path Stroke="White" StrokeThickness="2.4" StrokeStartLineCap="Round"
                                  Data="M 21,11 C 25,14 25,18 21,21 M 25,7 C 32,13 32,19 25,25" />
                        </Canvas>
                    </Viewbox>
                </Button>

                <Slider x:Name="VolumeSlider"
                        Grid.Column="1"
                        Minimum="0" Maximum="100"
                        TickFrequency="1"
                        IsSnapToTickEnabled="True"
                        VerticalAlignment="Center"
                        ValueChanged="VolumeSlider_ValueChanged" />

                <TextBlock x:Name="VolumePercentText"
                           Grid.Column="2"
                           Foreground="White"
                           FontWeight="SemiBold"
                           FontSize="17"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Text="60%" />
            </Grid>

            <TextBlock Grid.Row="5"
                       Text="MODO"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="15" />

            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton x:Name="StandardMode"
                             Grid.Column="0"
                             GroupName="Mode"
                             Content="25 / 5"
                             Background="#24985B"
                             Style="{StaticResource ModeButtonStyle}" />
                <RadioButton x:Name="ExtendedMode"
                             Grid.Column="1"
                             GroupName="Mode"
                             Content="50 / 10"
                             Background="#C6384E"
                             Style="{StaticResource ModeButtonStyle}" />
            </Grid>

            <Button Grid.Row="8"
                    Content="RESTABLECER AJUSTES"
                    Foreground="White"
                    Background="#22FFFFFF"
                    BorderBrush="#80FFFFFF"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    FontSize="13"
                    Cursor="Hand"
                    Click="Reset_Click" />

            <Button Grid.Row="10"
                    Content="LISTO"
                    Foreground="#174B91"
                    Background="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    FontSize="15"
                    Cursor="Hand"
                    Click="Done_Click" />
        </Grid>
    </Border>
</Window>
