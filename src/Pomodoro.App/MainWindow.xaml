<Window x:Class="Pomodoro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pomodoro"
        Width="320" Height="320"
        MinWidth="220" MinHeight="180"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="True"
        Background="#238F55"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="8"
                      CornerRadius="18"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border x:Name="Surface"
            CornerRadius="18"
            MouseLeftButtonDown="Surface_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush x:Name="BackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop x:Name="ColorStart" Color="#63B447" Offset="0" />
                <GradientStop x:Name="ColorEnd" Color="#16804D" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.66*" />
                <RowDefinition Height="0.34*" />
            </Grid.RowDefinitions>

            <Viewbox Grid.Row="0" Stretch="Uniform" Margin="8,24,8,0">
                <TextBlock x:Name="CountdownText"
                           Text="25:00"
                           Foreground="White"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="86"
                           TextWrapping="NoWrap"
                           TextAlignment="Center" />
            </Viewbox>

            <Viewbox Grid.Row="1" Stretch="Uniform" Margin="18,0,18,12">
                <TextBlock x:Name="PhaseText"
                           Text="TRABAJO"
                           Foreground="White"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontWeight="SemiBold"
                           FontSize="34"
                           TextWrapping="NoWrap"
                           TextAlignment="Center" />
            </Viewbox>

            <Button Grid.RowSpan="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Width="38" Height="38"
                    Padding="8"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="Ajustes"
                    WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="MenuButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Path x:Name="MenuPath"
                                  Stroke="White"
                                  StrokeThickness="2.6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="M 4,7 L 26,7 M 4,15 L 26,15 M 4,23 L 26,23"
                                  Stretch="Uniform"
                                  Margin="8" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuPath" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuPath" Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
